#!/bin/bash
set -uo pipefail

# Check if required arguments are provided
if [ $# -lt 2 ]; then
  echo "Usage: $0 <role: master|worker|all> <command>"
  exit 1
fi

# Assign the first argument as ROLE and shift to capture the remaining as COMMAND
ROLE="$1"
shift
COMMAND="$*"

# SSH options
ssh_opts="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o ConnectTimeout=10"

# Fetch node hostnames from OpenShift based on their labels
MASTER_NODES=$(oc get nodes -l "node-role.kubernetes.io/master" -o jsonpath='{.items[*].status.addresses[?(@.type=="Hostname")].address}' 2>/dev/null)
WORKER_NODES=$(oc get nodes -l "node-role.kubernetes.io/worker" -o jsonpath='{.items[*].status.addresses[?(@.type=="Hostname")].address}' 2>/dev/null)

# Main function to iterate through nodes and execute the command
run_on_nodes() {
  local nodes="$1"
  for Hostname in $nodes; do
    # Execute command via SSH on CoreOS nodes (default user: core)
    # 2>&1 redirects stderr to stdout so all output is captured in the variable
    output=$(ssh $ssh_opts core@"$Hostname" "$COMMAND" 2>&1)
    status=$?

    # Format the header line:
    # '▶ Node:' followed by the hostname left-aligned in a 45-character field
    # followed by the execution status [ OK ] or [ FAIL ]
    if [ $status -eq 0 ]; then
      printf "▶ Node: %-45s [ OK ]\n" "$Hostname"

      # If command output exists, indent every line by 4 spaces for better readability
      [ -n "$output" ] && echo "$output" | sed 's/^/   /'
    else

      # Print failure message or error output with indentation
      printf "▶ Node: %-45s [ FAIL ]\n" "$Hostname"
      [ -n "$output" ] && echo "$output" | sed 's/^/   /'
    fi

    # Print a newline between nodes for visual clarity
    echo ""
  done
}

# Logic to determine which node group to target based on the input ROLE
case "$ROLE" in
  master) run_on_nodes "$MASTER_NODES" ;;
  worker) run_on_nodes "$WORKER_NODES" ;;
  all)    run_on_nodes "$MASTER_NODES"; run_on_nodes "$WORKER_NODES" ;;
  *)      echo "FAIL: role must be master|worker|all"; exit 1 ;;
esac
